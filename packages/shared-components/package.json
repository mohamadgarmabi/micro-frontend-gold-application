{
  "name": "@gold/shared-components",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "preview": "vite preview --port 5100 --strictPort"
  },
  "nx": {
    "name": "shared-components",
    "projectType": "library",
    "sourceRoot": "packages/shared-components/src",
    "implicitDependencies": [
      "design-system"
    ],
    "targets": {
      "dev": {
        "executor": "nx:run-commands",
        "continuous": true,
        "syncGenerators": [
          "@juristr/nx-tailwind-sync:source-directives"
        ],
        "dependsOn": [
          "design-system:dev"
        ],
        "options": {
          "command": "vite --port 5100 --strictPort",
          "cwd": "packages/shared-components"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "syncGenerators": [
          "@juristr/nx-tailwind-sync:source-directives"
        ],
        "dependsOn": [
          "design-system:dev"
        ],
        "options": {
          "command": "vite build",
          "cwd": "packages/shared-components"
        }
      }
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@gold/design-system": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*/index.tsx",
    "./accordion": "./src/components/accordion/index.tsx",
    "./alert-dialog": "./src/components/alert-dialog/index.tsx",
    "./autocomplete": "./src/components/autocomplete/index.tsx",
    "./avatar": "./src/components/avatar/index.tsx",
    "./badge": "./src/components/badge/index.tsx",
    "./button": "./src/components/button/index.tsx",
    "./card": "./src/components/card/index.tsx",
    "./checkbox-group": "./src/components/checkbox-group/index.tsx",
    "./checkbox": "./src/components/checkbox/index.tsx",
    "./collapsible": "./src/components/collapsible/index.tsx",
    "./combobox": "./src/components/combobox/index.tsx",
    "./context-menu": "./src/components/context-menu/index.tsx",
    "./dialog": "./src/components/dialog/index.tsx",
    "./drawer": "./src/components/drawer/index.tsx",
    "./field": "./src/components/field/index.tsx",
    "./fieldset": "./src/components/fieldset/index.tsx",
    "./form": "./src/components/form/index.tsx",
    "./input": "./src/components/input/index.tsx",
    "./menu": "./src/components/menu/index.tsx",
    "./menubar": "./src/components/menubar/index.tsx",
    "./meter": "./src/components/meter/index.tsx",
    "./navigation-menu": "./src/components/navigation-menu/index.tsx",
    "./number-field": "./src/components/number-field/index.tsx",
    "./otp-field": "./src/components/otp-field/index.tsx",
    "./popover": "./src/components/popover/index.tsx",
    "./price-display": "./src/components/price-display/index.tsx",
    "./preview-card": "./src/components/preview-card/index.tsx",
    "./progress": "./src/components/progress/index.tsx",
    "./radio-group": "./src/components/radio-group/index.tsx",
    "./radio": "./src/components/radio/index.tsx",
    "./scroll-area": "./src/components/scroll-area/index.tsx",
    "./select": "./src/components/select/index.tsx",
    "./separator": "./src/components/separator/index.tsx",
    "./slider": "./src/components/slider/index.tsx",
    "./sonner": "./src/components/sonner/index.tsx",
    "./switch": "./src/components/switch/index.tsx",
    "./tabs": "./src/components/tabs/index.tsx",
    "./toast": "./src/components/toast/index.tsx",
    "./toggle-group": "./src/components/toggle-group/index.tsx",
    "./toggle": "./src/components/toggle/index.tsx",
    "./toolbar": "./src/components/toolbar/index.tsx",
    "./tooltip": "./src/components/tooltip/index.tsx"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.15.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~5.9.2",
    "vite": "^8.0.13"
  }
}
