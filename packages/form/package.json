{
  "name": "@gold/form",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "nx": {
    "name": "form",
    "projectType": "library",
    "sourceRoot": "packages/form/src",
    "implicitDependencies": ["design-system", "shared-components"],
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc --noEmit",
          "cwd": "packages/form"
        }
      }
    }
  },
  "dependencies": {
    "@gold/design-system": "workspace:*",
    "@gold/shared-components": "workspace:*",
    "@tanstack/react-form": "^1.19.2",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "~5.9.2"
  }
}
