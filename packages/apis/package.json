{
  "name": "@gold/apis",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth/index.ts",
    "./config": "./src/config/index.ts",
    "./client": "./src/client/index.ts",
    "./posts": "./src/posts/index.ts",
    "./posts/controller": "./src/posts/controller/index.ts",
    "./posts/endpoints": "./src/posts/endpoints/index.ts",
    "./posts/dto": "./src/posts/dto/index.ts"
  },
  "nx": {
    "name": "apis",
    "projectType": "library",
    "sourceRoot": "packages/apis/src",
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc --noEmit",
          "cwd": "packages/apis"
        }
      }
    }
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.13.2"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
