{
  "name": "@gold/application-pwa",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 4400 --strictPort",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview --port 4400 --strictPort"
  },
  "nx": {
    "name": "application-pwa",
    "projectType": "application",
    "sourceRoot": "apps/application-pwa/src",
    "implicitDependencies": [
      "design-system",
      "shared-components",
      "form",
      "apis"
    ],
    "targets": {
      "dev": {
        "executor": "nx:run-commands",
        "continuous": true,
        "syncGenerators": [
          "@juristr/nx-tailwind-sync:source-directives"
        ],
        "dependsOn": [
          "shared-components:dev"
        ],
        "options": {
          "command": "vite dev --port 4400 --strictPort",
          "cwd": "apps/application-pwa"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "syncGenerators": [
          "@juristr/nx-tailwind-sync:source-directives"
        ],
        "dependsOn": [
          "shared-components:build"
        ],
        "options": {
          "command": "vite build",
          "cwd": "apps/application-pwa"
        }
      }
    }
  },
  "dependencies": {
    "@gold/apis": "workspace:*",
    "@gold/design-system": "workspace:*",
    "@gold/form": "workspace:*",
    "@gold/shared-components": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-store": "latest",
    "@tanstack/react-virtual": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@tanstack/store": "latest",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.9.1",
    "tailwindcss": "^4.1.18",
    "workbox-window": "^7.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.9.2",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.0.1"
  }
}
