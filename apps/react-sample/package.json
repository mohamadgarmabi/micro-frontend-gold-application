{
  "name": "@gold/react-sample",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "preview": "vite preview --port 4200 --strictPort"
  },
  "nx": {
    "name": "react-sample",
    "projectType": "application",
    "sourceRoot": "apps/react-sample/src",
    "implicitDependencies": ["design-system", "shared-components", "form"],
    "targets": {
      "dev": {
        "executor": "nx:run-commands",
        "continuous": true,
        "syncGenerators": ["@juristr/nx-tailwind-sync:source-directives"],
        "dependsOn": ["shared-components:dev"],
        "options": {
          "command": "vite --port 4200 --strictPort",
          "cwd": "apps/react-sample"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "syncGenerators": ["@juristr/nx-tailwind-sync:source-directives"],
        "dependsOn": ["shared-components:build"],
        "options": {
          "command": "vite build",
          "cwd": "apps/react-sample"
        }
      }
    }
  },
  "dependencies": {
    "@gold/design-system": "workspace:*",
    "@gold/form": "workspace:*",
    "@gold/shared-components": "workspace:*",
    "@module-federation/runtime": "^2.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.15.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~5.9.2",
    "vite": "^8.0.13"
  }
}
